# Database
DATABASE_URL=postgresql://kb_user:kb_password@localhost:5432/kb_estate

# Redis
REDIS_URL=redis://localhost:6379/0

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=your-secure-api-key-here

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Object Storage (Optional)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=kb-estate-raw-data

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Rate Limiting
DEFAULT_RATE_LIMIT_PER_MINUTE=60
KB_RATE_LIMIT_PER_MINUTE=30

# Notification (Optional)
SLACK_WEBHOOK_URL=
SENTRY_DSN=
